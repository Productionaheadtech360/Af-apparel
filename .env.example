# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://afapparel:afapparel@localhost:5432/afapparel_db
DATABASE_URL_SYNC=postgresql://afapparel:afapparel@localhost:5432/afapparel_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── QuickBooks Online ────────────────────────────────────────────────────────
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:8000/api/v1/admin/quickbooks/callback
QB_ENVIRONMENT=sandbox
QB_COMPANY_ID=
QB_ACCESS_TOKEN=
QB_REFRESH_TOKEN=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
EMAIL_FROM_ADDRESS=noreply@karauxbaia.resend.app
EMAIL_FROM_NAME=AF Apparels
ADMIN_NOTIFICATION_EMAIL=your@email.com

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=afapparel-media
AWS_S3_REGION=us-east-1
CDN_BASE_URL=https://media.afapparels.com

# ─── Shopify (migration only) ─────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_...

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_APP_URL=http://localhost:3000
